{
  "name": "@tally-bridge/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "test": "node --test --experimental-strip-types test/*.test.ts",
    "pretest": "cd ../.. && npm run build -w @tally-bridge/core -w @tally-bridge/crypto -w @tally-bridge/protocol"
  },
  "dependencies": {
    "@tally-bridge/core": "*",
    "@tally-bridge/crypto": "*",
    "@tally-bridge/protocol": "*",
    "@neondatabase/serverless": "^0.10.4"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2"
  }
}
