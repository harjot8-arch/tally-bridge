{
  "name": "@tally-bridge/bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Tally Bridge — reads a business's books out of Tally, encrypts them at the edge, and pushes them to the owner's own dashboard.",
  "author": "Tally Bridge",
  "main": "dist/main/index.js",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "start": "electron .",
    "dev:rebuild-native": "node scripts/rebuild-native-for-electron.mjs",
    "dev:restore-native": "node scripts/rebuild-native-for-electron.mjs --to-node",
    "build": "node scripts/clean.mjs && tsc -p tsconfig.json && node scripts/build-assets.mjs",
    "dist": "npm run build && electron-builder --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "test": "node --test --experimental-strip-types test/*.test.ts",
    "visual": "npm run build && electron scripts/visual-harness.mjs",
    "visual:show": "npm run build && electron scripts/visual-harness.mjs --show",
    "pretest": "cd ../.. && npm run build -w @tally-bridge/core && npm run build -w @tally-bridge/crypto && npm run build -w @tally-bridge/protocol && npm run build -w @tally-bridge/tally && npm run build -w @tally-bridge/viewmodel && npm run build -w @tally-bridge/sync"
  },
  "dependencies": {
    "@scure/bip39": "^2.2.0",
    "@tally-bridge/core": "*",
    "@tally-bridge/crypto": "*",
    "@tally-bridge/protocol": "*",
    "@tally-bridge/sync": "*",
    "@tally-bridge/tally": "*",
    "@tally-bridge/viewmodel": "*",
    "electron-updater": "^6.8.9",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.6",
    "electron": "^43.1.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.tallybridge.desktop",
    "productName": "Tally Bridge",
    "electronVersion": "43.1.1",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "!**/*.map",
      "!**/*.d.ts"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "npmRebuild": true,
    "win": {
      "target": "nsis",
      "artifactName": "Tally-Bridge-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
