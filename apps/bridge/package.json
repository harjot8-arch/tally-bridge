{
  "name": "@tally-bridge/bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "start": "electron .",
    "dev:rebuild-native": "node scripts/rebuild-native-for-electron.mjs",
    "dev:restore-native": "node scripts/rebuild-native-for-electron.mjs --to-node",
    "build": "node scripts/clean.mjs && tsc -p tsconfig.json && node scripts/build-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "test": "node --test --experimental-strip-types test/*.test.ts",
    "visual": "npm run build && electron scripts/visual-harness.mjs",
    "visual:show": "npm run build && electron scripts/visual-harness.mjs --show"
  },
  "dependencies": {
    "@scure/bip39": "^2.2.0",
    "@tally-bridge/core": "*",
    "@tally-bridge/crypto": "*",
    "@tally-bridge/protocol": "*",
    "@tally-bridge/sync": "*",
    "@tally-bridge/tally": "*",
    "@tally-bridge/viewmodel": "*",
    "electron-updater": "^6.8.9",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.6",
    "electron": "^43.1.1",
    "typescript": "^5.7.2"
  }
}
