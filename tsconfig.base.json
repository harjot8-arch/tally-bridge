{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,

    // Write `./foo.ts` in source; tsc rewrites it to `./foo.js` on emit. This lets
    // `node --experimental-strip-types` run the sources directly (it does no path rewriting,
    // so a `.js` specifier pointing at a `.ts` file would not resolve) while still emitting
    // correct NodeNext output.
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true
  }
}
