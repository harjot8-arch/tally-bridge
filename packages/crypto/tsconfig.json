{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    // This package is compiled into the browser dashboard as well as the Electron main
    // process, and it uses WebCrypto (crypto.subtle), CompressionStream and btoa/atob —
    // all of which are DOM-lib types. Including DOM here is a statement of fact about where
    // this code runs, not a convenience.
    "lib": ["ES2022", "DOM"]
  },
  "include": ["src/**/*"]
}
